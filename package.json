{
	"name": "lignee",
	"type": "module",
	"version": "0.1.0",
	"description": "A library for parsing, editing, and writing GEDCOM files.",
	"homepage": "https://github.com/gilleswaeber/lignee",
	"author": "Gilles Waeber <moi@gilleswaeber.ch>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gilleswaeber/lignee.git"
	},
	"license": "MIT",
	"keywords": [],
	"sideEffects": false,
	"packageManager": "pnpm@10.32.1",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"import": "./dist/index.js",
			"require": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"scripts": {
		"build": "tsdown",
		"test": "vitest",
		"format": "prettier --write src test ./*.json",
		"lint": "eslint src"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitest/coverage-v8": "4.1.0",
		"eslint": "^10.2.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tsdown": "^0.21.4",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.0"
	}
}
